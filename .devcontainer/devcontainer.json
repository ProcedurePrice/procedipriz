{
  "name": "ProcediPriz",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker",
        "ms-python.python"
      ]
    }
  },
  "forwardPorts": [3000, 8080],
  "postCreateCommand": "cd backend && go mod download && cd ../frontend && npm ci"
}